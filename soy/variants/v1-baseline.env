# v1 – Baseline (Implicit Trust)
# Access control only at the API Gateway. Microservices trust the gateway.
ZT_AC4A=false
ZT_SR=false
ZT_MTLS=false
ZT_RA=false

# Docker profiles to activate (empty = none)
ZT_PROFILES=

# Upstream service URLs (plain HTTP – no mTLS)
EXERCISE_SERVICE_URL=http://ms-exercise:8080
OTHER_SERVICE_URL=http://ms-other:8080
