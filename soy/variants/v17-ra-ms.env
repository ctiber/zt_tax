# v17 – Risk Analysis at Microservice Level only
# RA enforcement moves from the API gateway to each microservice.
# For async patterns (queue/topic), RA fires at message-consumption time
# rather than at gateway ingress — breaking communication-pattern independence.
ZT_AC4A=false
ZT_SR=false
ZT_MTLS=false
ZT_RA=false
ZT_RA_MS=true

ZT_PROFILES=ra

EXERCISE_SERVICE_URL=http://ms-exercise:8080
OTHER_SERVICE_URL=http://ms-other:8080

RA_SERVICE_URL=http://risk-analysis:9000
