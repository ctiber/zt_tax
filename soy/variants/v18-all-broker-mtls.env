# v18 – All primitives + Microservice-level RA + Broker mTLS
# Extends v16 with:
#   ZT_RA_MS=true  – RA also enforced at each microservice (per-message for async)
#   ZT_BROKER_MTLS=true – amqps:// for RabbitMQ, SSL for Kafka
ZT_AC4A=true
ZT_SR=true
ZT_MTLS=true
ZT_RA=true
ZT_RA_MS=true
ZT_BROKER_MTLS=true

ZT_PROFILES=sr,mtls,ra

EXERCISE_SERVICE_URL=https://nginx-exercise:8443
OTHER_SERVICE_URL=https://nginx-other:8443

VAULT_ADDR=http://vault:8200
VAULT_TOKEN=soy-dev-root-token
VAULT_SECRET_PATH=secret/data/soy

RA_SERVICE_URL=http://risk-analysis:9000
VAULT_RENEWAL_INTERVAL_MS=3600000
