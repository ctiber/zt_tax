# v3 – Secret Rotation (SR only)
# Secrets (JWT secret, DB password) fetched from HashiCorp Vault at startup.
ZT_AC4A=false
ZT_SR=true
ZT_MTLS=false
ZT_RA=false
ZT_RA_MS=false

ZT_PROFILES=sr

EXERCISE_SERVICE_URL=http://ms-exercise:8080
OTHER_SERVICE_URL=http://ms-other:8080

# Vault configuration
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=soy-dev-root-token
VAULT_SECRET_PATH=secret/data/soy
# Secret renewal interval – long enough to never fire during a load test run
VAULT_RENEWAL_INTERVAL_MS=3600000
