# v4 – Mutual TLS (mTLS only)
# All inter-service traffic encrypted with mutual certificate authentication.
ZT_AC4A=false
ZT_SR=false
ZT_MTLS=true
ZT_RA=false
ZT_RA_MS=false

ZT_PROFILES=mtls

# mTLS: traffic goes through Nginx sidecar proxies on port 8443
EXERCISE_SERVICE_URL=https://nginx-exercise:8443
OTHER_SERVICE_URL=https://nginx-other:8443
