# v6 – All-GW (AC4A + SR + mTLS + RA at gateway)
ZT_AC4A=true
ZT_SR=true
ZT_MTLS=true
ZT_RA=true
ZT_RA_MS=false

ZT_PROFILES=sr,mtls,ra

EXERCISE_SERVICE_URL=https://nginx-exercise:8443
OTHER_SERVICE_URL=https://nginx-other:8443

VAULT_ADDR=http://vault:8200
VAULT_TOKEN=soy-dev-root-token
VAULT_SECRET_PATH=secret/data/soy
RA_SERVICE_URL=http://risk-analysis:9000
# Secret renewal interval – long enough to never fire during a load test run
VAULT_RENEWAL_INTERVAL_MS=3600000
